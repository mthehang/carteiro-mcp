# ============================================================================
# Carteiro MCP - Environment Configuration
# ============================================================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA comite o .env.

# ----------------------------------------------------------------------------
# Transport
# ----------------------------------------------------------------------------
# Como o MCP server expoe as tools.
#   stdio = para Claude Desktop, Claude Code, Cursor (default)
#   http  = Streamable HTTP em /mcp (para n8n, clientes remotos)
#   both  = stdio + http simultaneamente
TRANSPORT=stdio

# Porta do servidor HTTP (se TRANSPORT inclui http)
HTTP_PORT=3000

# ----------------------------------------------------------------------------
# Admin UI
# ----------------------------------------------------------------------------
# Interface web para escanear QR, ver status, fazer logout.
ADMIN_PORT=3001

# Token bearer para proteger rotas admin. Gere com:
#   openssl rand -hex 32
ADMIN_TOKEN=

# ----------------------------------------------------------------------------
# Persistencia
# ----------------------------------------------------------------------------
# Diretorio para sessoes do WhatsApp e banco SQLite.
# Em Docker, mountar como volume nomeado.
DATA_DIR=./data

# Chave AES-256-GCM para encriptar conteudo de mensagens no SQLite.
# Gere com: openssl rand -hex 32  (deve ter 64 caracteres hex = 32 bytes)
# CRITICO: se perder essa chave, mensagens antigas viram lixo.
DATA_ENCRYPTION_KEY=

# Dias para reter mensagens no banco antes de auto-purge. 0 = sem purge.
MESSAGE_RETENTION_DAYS=90

# ----------------------------------------------------------------------------
# WhatsApp / Baileys
# ----------------------------------------------------------------------------
# Nome que aparece em "Linked Devices" no celular do usuario.
WA_BROWSER_NAME=Carteiro MCP

# Reconectar automaticamente se a conexao cair.
WA_AUTO_RECONNECT=true

# Numero de telefone para pairing code (E.164, ex: +5511999999999).
# Opcional. Se vazio, fluxo padrao e QR code.
WA_PHONE_NUMBER=

# ----------------------------------------------------------------------------
# Seguranca
# ----------------------------------------------------------------------------
# Whitelist de contatos permitidos (CSV de E.164).
# Vazio = sem whitelist (qualquer contato pode receber).
# Exemplo: ALLOWED_CONTACTS=+5511999999999,+5511888888888
ALLOWED_CONTACTS=

# Limite de mensagens enviadas por minuto (token bucket).
RATE_LIMIT_SEND_PER_MIN=30

# ----------------------------------------------------------------------------
# Logs
# ----------------------------------------------------------------------------
# Niveis: trace, debug, info, warn, error, fatal, silent
LOG_LEVEL=info

# Formatar logs como JSON (true) ou pretty (false).
LOG_JSON=false
